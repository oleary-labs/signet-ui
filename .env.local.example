# Chain configuration
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=31337

# Contract addresses (populated by devnet/start.sh)
NEXT_PUBLIC_GROUP_FACTORY_ADDRESS=0x
NEXT_PUBLIC_ACCOUNT_FACTORY_ADDRESS=0x
NEXT_PUBLIC_ENTRYPOINT_ADDRESS=0x

# Bundler
NEXT_PUBLIC_BUNDLER_URL=http://127.0.0.1:4337

# Paymaster sponsorship (ERC-7677)
# Set USE_PAYMASTER=true and PAYMASTER_ADDRESS to the deployed VerifyingPaymaster
# for sponsored UserOps. When USE_PAYMASTER is false (default), the SignetAccount
# funds its own gas — useful for local devnet without a paymaster.
NEXT_PUBLIC_USE_PAYMASTER=false
NEXT_PUBLIC_PAYMASTER_ADDRESS=0x

# Bootstrap group (Signet's own group for Console auth)
NEXT_PUBLIC_BOOTSTRAP_GROUP=0x
NEXT_PUBLIC_BOOTSTRAP_NODES=http://127.0.0.1:8080,http://127.0.0.1:8081,http://127.0.0.1:8082

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
# Add http://localhost:3000/auth/callback as an Authorized Redirect URI
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
